{
  "name": "@pit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:cleanup-smoke": "tsx src/db/cleanupDevSmokeData.ts",
    "start": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build --workspace @pit/shared && npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "@pit/shared": "0.1.0",
    "@supabase/supabase-js": "^2.106.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
