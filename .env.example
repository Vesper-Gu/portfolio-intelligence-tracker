# Local backend
API_HOST=127.0.0.1
API_PORT=8787
CORS_ORIGIN=http://127.0.0.1:5173
DATA_REPOSITORY=mock
AUTH_MODE=local-dev
DEV_USER_ID=local-dev-user

# Supabase / PostgreSQL; required only for persistent or authenticated mode
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ingest-uploads

# Optional AI providers for extraction and grounded answers
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
VISION_PROVIDER=
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_VISION_MODEL=kimi-k2.6
RAG_LLM_API_KEY=
RAG_LLM_BASE_URL=https://api.deepseek.com
RAG_LLM_MODEL=deepseek-v4-flash

# Browser auth; set together with AUTH_MODE=external for multi-user deployment
VITE_API_BASE_URL=http://127.0.0.1:8787
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cost controls and signed previews
MAX_UPLOAD_MB=20
IMAGE_PREVIEW_EXPIRES_IN_SECONDS=300
DAILY_VISION_LIMIT=50
DAILY_LLM_LIMIT=200
LOG_LEVEL=info
# Comma-separated synthetic ingest IDs; required only when running db:cleanup-smoke.
SMOKE_INGEST_IDS=

# Optional observability
SENTRY_DSN=
